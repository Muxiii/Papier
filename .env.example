# LLM_PROVIDER：anthropic | openai | moonshot（未设置时默认 anthropic）

# --- Moonshot（Kimi），OpenAI 兼容 ---
# LLM_PROVIDER=moonshot
# MOONSHOT_API_KEY=
# MOONSHOT_MODEL=moonshot-v1-8k
# MOONSHOT_BASE_URL=https://api.moonshot.ai/v1

# --- Anthropic ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- OpenAI ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# API 服务端口（默认 8787）
# PORT=8787

# 前端（Vite）生产环境 API 基地址（本地开发一般留空）
# 例如：https://your-render-service.onrender.com
# VITE_API_BASE_URL=
